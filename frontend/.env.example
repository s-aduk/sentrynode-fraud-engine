# Copy to .env.local and fill in with the value from the `sam deploy`
# output "IngestionApiUrl". Never commit .env.local — it's git-ignored.
NEXT_PUBLIC_INGESTION_API_URL=https://REPLACE-ME.execute-api.us-east-1.amazonaws.com/prod/transaction

# Set to "true" once a read endpoint for the Monitoring Feed exists.
# Until then the feed shows an honest "not connected" state (see
# frontend/README.md and docs/architecture.md "out of scope" section).
NEXT_PUBLIC_MONITORING_API_URL=
